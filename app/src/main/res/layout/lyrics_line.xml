<?xml version="1.0" encoding="utf-8"?>
<!-- Mirrors Apple's res/layout/lyrics_line.xml (id 0x7f0d01cc) — the layout
     I0.r() inflates at viewType=0 (classes2_decomp.c:1279773). Apple's version
     stacks three CustomTextViews (main / pronunciation / translation); we only
     keep the main one because our parser doesn't produce the other two. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/song_lyrics_line_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_lyrics_line_ripple"
    android:paddingTop="@dimen/lyrics_text_padding_top"
    android:paddingBottom="@dimen/lyrics_text_padding_bottom"
    android:paddingStart="@dimen/lyrics_text_padding_horiz"
    android:paddingEnd="@dimen/lyrics_text_padding_horiz">

    <TextView
        android:id="@+id/song_lyrics_line"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="@dimen/lyrics_line_text_size"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:textIsSelectable="false"
        android:textDirection="anyRtl"
        android:ellipsize="end"
        android:includeFontPadding="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="And they never they never ever thought" />
</androidx.constraintlayout.widget.ConstraintLayout>
